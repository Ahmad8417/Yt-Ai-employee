# AI Employee Environment Configuration - GOLD TIER
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# ============================================
# GMAIL API CONFIGURATION
# ============================================
# Path to your Gmail OAuth credentials.json file
GMAIL_CREDENTIALS_PATH=./credentials.json

# ============================================
# SMTP CONFIGURATION (for Email MCP)
# ============================================
# For Gmail: Use smtp.gmail.com with App Password (NOT your regular password)
# Generate App Password: https://myaccount.google.com/apppasswords
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here

# ============================================
# LINKEDIN API CONFIGURATION (optional)
# ============================================
# Get tokens from LinkedIn Developer Portal: https://www.linkedin.com/developers/
# Required scope: w_member_social
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_USER_ID=

# ============================================
# VAULT PATH
# ============================================
AI_EMPLOYEE_VAULT=./AI_Employee_Vault

# ============================================
# PYTHON PATH (optional)
# ============================================
PYTHON_PATH=python

# ============================================
# GOLD TIER - DOCKER & DATABASE
# ============================================

# PostgreSQL Database
POSTGRES_PASSWORD=your_secure_postgres_password

# Odoo ERP Configuration
ODOO_DB=ai_employee_db
ODOO_USER=admin
ODOO_ADMIN_PASSWORD=your_secure_odoo_admin_password

# pgAdmin (Optional Database Management UI)
PGADMIN_EMAIL=admin@yourdomain.com
PGADMIN_PASSWORD=your_secure_pgadmin_password

# ============================================
# GOLD TIER - FACEBOOK/INSTAGRAM GRAPH API
# Get from: https://developers.facebook.com/
# ============================================
FACEBOOK_ACCESS_TOKEN=your_long_lived_access_token
FACEBOOK_PAGE_ID=your_facebook_page_id
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id

# ============================================
# GOLD TIER - RALPH WIGGUM LOOP
# ============================================
RALPH_MAX_ITERATIONS=10
RALPH_COMPLETION_PROMISE=TASK_COMPLETE

# ============================================
# GOLD TIER - LOGGING & SECURITY
# ============================================
LOG_LEVEL=INFO
# Generate with: openssl rand -hex 32
SECRET_KEY=your_random_secret_key_here
AUDIT_LOG_RETENTION_DAYS=90

# ============================================
# DOCKER COMPOSE
# ============================================
COMPOSE_PROJECT_NAME=ai_employee_gold
